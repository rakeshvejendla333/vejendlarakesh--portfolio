ex-direction: column;\r\n    gap: 0px;\r\n    padding: 0px 2px;\r\n`\r\nconst Title = styled.div`\r\n    font-size: 20px;\r\n    font-weight: 600;\r\n    color: ${({ theme }) => theme.text_secondary};\r\n    overflow: hidden;\r\n    display: -webkit-box;\r\n    max-width: 100%;\r\n    -webkit-line-clamp: 2;\r\n    -webkit-box-orient: vertical;\r\n    overflow: hidden;\r\n    text-overflow: ellipsis;\r\n`\r\n\r\nconst Date = styled.div`\r\n    font-size: 12px;\r\n    margin-left: 2px;\r\n    font-weight: 400;\r\n    color: ${({ theme }) => theme.text_secondary + 80};\r\n    @media only screen and (max-width: 768px){\r\n        font-size: 10px;\r\n    }\r\n`\r\n\r\n\r\nconst Description = styled.div`\r\n    font-weight: 400;\r\n    color: ${({ theme }) => theme.text_secondary + 99};\r\n    overflow: hidden;\r\n    margin-top: 8px;\r\n    display: -webkit-box;\r\n    max-width: 100%;\r\n    -webkit-line-clamp: 3;\r\n    -webkit-box-orient: vertical;\r\n    text-overflow: ellipsis;\r\n`\r\n\r\nconst Members = styled.div`\r\n    display: flex;\r\n    align-items: center;\r\n    padding-left: 10px;\r\n`\r\nconst Avatar = styled.img`\r\n    width: 38px;\r\n    height: 38px;\r\n    border-radius: 50%;\r\n    margin-left: -10px;\r\n    background-color: ${({ theme }) => theme.white};\r\n    box-shadow: 0 0 10px rgba(0,0,0,0.2);\r\n    border: 3px solid ${({ theme }) => theme.card};\r\n`\r\n\r\nconst ProjectCards = ({project,setOpenModal}) => {\r\n    return (\r\n        <Card onClick={() => setOpenModal({state: true, project: project})}>\r\n            <Image src={project.image}/>\r\n            <Tags>\r\n                {project.tags?.map((tag, index) => (\r\n                <Tag>{tag}</Tag>\r\n                ))}\r\n            </Tags>\r\n            <Details>\r\n                <Title>{project.title}</Title>\r\n                <Date>{project.date}</Date>\r\n                <Description>{project.description}</Description>\r\n            </Details>\r\n            <Members>\r\n                {project.member?.map((member) => (\r\n                    <Avatar src={member.img}/>\r\n                ))}\r\n            </Members>\r\n            */\r\n            {/* <Button>View Project</Button> */}\r\n       // </Card>\r\n   // )\r\n//}\r\n\r\n//export default ProjectCards\r\n","C:\\Users\\RAKESH\\Downloads\\raki2\\vejendlarakesh--portfolio\\src\\components\\HeroBgAnimation\\index.js",[],[],"C:\\Users\\RAKESH\\Downloads\\raki2\\vejendlarakesh--portfolio\\src\\themes\\default.js",[],[],"C:\\Users\\RAKESH\\Downloads\\raki2\\vejendlarakesh--portfolio\\src\\components\\HeroBgAnimation\\HeroBgAnimationStyle.js",[],[],"C:\\Users\\RAKESH\\Downloads\\raki2\\vejendlarakesh--portfolio\\src\\components\\About\\AboutStyle.js",[],[],{"ruleId":"154","severity":1,"message":"155","line":8,"column":8,"nodeType":"156","messageId":"157","endLine":8,"endColumn":13},{"ruleId":"154","severity":1,"message":"158","line":10,"column":8,"nodeType":"156","messageId":"157","endLine":10,"endColumn":16},{"ruleId":"154","severity":1,"message":"159","line":31,"column":20,"nodeType":"156","messageId":"157","endLine":31,"endColumn":31},{"ruleId":"154","severity":1,"message":"160","line":9,"column":9,"nodeType":"156","messageId":"157","endLine":9,"endColumn":14},{"ruleId":"161","severity":1,"message":"162","line":15,"column":11,"nodeType":"163","endLine":15,"endColumn":121},{"ruleId":"154","severity":1,"message":"164","line":3,"column":30,"nodeType":"156","messageId":"157","endLine":3,"endColumn":35},{"ruleId":"154","severity":1,"message":"165","line":3,"column":37,"nodeType":"156","messageId":"157","endLine":3,"endColumn":41},{"ruleId":"154","severity":1,"message":"166","line":3,"column":43,"nodeType":"156","messageId":"157","endLine":3,"endColumn":56},{"ruleId":"154","severity":1,"message":"167","line":3,"column":58,"nodeType":"156","messageId":"157","endLine":3,"endColumn":75},{"ruleId":"154","severity":1,"message":"168","line":3,"column":77,"nodeType":"156","messageId":"1